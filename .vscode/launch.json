{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run kittenclaw (opencode)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "uv",
      "runtimeArgs": [
        "run",
        "python",
        "-m",
        "kittenclaw",
        "--preset",
        "opencode"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run kittenclaw (gemini)",
