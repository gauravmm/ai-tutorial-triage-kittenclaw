# Telegram bot token - get one from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# OpenRouter API key - sign up free at https://openrouter.ai/
# Used by the `openrouter` preset.
OPENROUTER_API_KEY=

# OpenCode API key - free signup at https://opencode.ai/zen/
# Used by the default `opencode` preset. Sign up your own account.
OPENCODE_API_KEY=

# Google AI Studio (Gemini) API key - free signup at https://aistudio.google.com/
# Used by the `gemini` preset. Sign up your own account; no card needed.
GEMINI_API_KEY=
